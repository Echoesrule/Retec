SECRET_KEY=change-this-in-production

# Database
DATABASE_URL=sqlite:///portfolio.db

# SMTP contact form
# Gmail example:
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USE_SSL=false
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-google-app-password
# MAIL_FROM=your-email@gmail.com
# MAIL_TO=contact.retec@gmail.com
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_TO=contact.retec@gmail.com

# Brevo (Sendinblue) - newsletter subscriber sync
# Get your API key and list ID from https://app.brevo.com
BREVO_API_KEY=
BREVO_LIST_ID=

# ZeroBounce - real email verification (optional, free tier: 100/mo)
# Sign up at https://www.zerobounce.net and get an API key
ZEROBOUNCE_API_KEY=

# Cloudinary - persistent image hosting (optional, free tier available)
# Get your URL from https://cloudinary.com/console → Dashboard → "API Environment variable"
# Format: cloudinary://api_key:api_secret@cloud_name
